# =============================================================================
# ZhaoYaoJing Configuration / 照妖镜配置
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# LLM Provider (at least one required) / 模型配置（至少配一个）
# =============================================================================

# OpenAI
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Qwen / 通义千问
# QWEN_API_KEY=sk-your-qwen-key
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-max

# Google Gemini
# GEMINI_API_KEY=your-gemini-key
# GEMINI_MODEL=gemini-2.0-flash

# MiniMax
# MINIMAX_API_KEY=your-minimax-key
# MINIMAX_MODEL=minimax-m2.7
# MINIMAX_GROUP_ID=

# =============================================================================
# Server / 服务器
# =============================================================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# CORS — comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-domain.com

# =============================================================================
# Database / 数据库
# =============================================================================
# Dev (SQLite, default)
# DATABASE_URL=sqlite+aiosqlite:///./zhaoyaojing.db
# Production (PostgreSQL, used by docker-compose.prod.yml automatically)
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/zhaoyaojing
# POSTGRES_PASSWORD=your-secure-password

# =============================================================================
# Feishu Bot / 飞书机器人
# https://open.feishu.cn/app → Create App
# =============================================================================
# FEISHU_APP_ID=cli_your_app_id
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_VERIFICATION_TOKEN=your_verification_token
# FEISHU_ENCRYPT_KEY=your_encrypt_key

# =============================================================================
# WeCom Bot / 企业微信机器人
# 企业微信管理后台 → 应用管理 → 创建应用
# =============================================================================
# WECOM_CORP_ID=your_corp_id
# WECOM_AGENT_ID=your_agent_id
# WECOM_SECRET=your_secret
# WECOM_TOKEN=your_token
# WECOM_ENCODING_AES_KEY=your_aes_key

# =============================================================================
# Slack Bot
# https://api.slack.com/apps → Create App
# =============================================================================
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_SIGNING_SECRET=your_signing_secret
# SLACK_APP_TOKEN=xapp-your-app-token

# =============================================================================
# Domain (for docker-compose.prod.yml CORS)
# =============================================================================
# DOMAIN=your-domain.com
